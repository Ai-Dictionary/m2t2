<div class="form-box">
    <div class="row">
        <div class="col">
            <div class="form-group">
                <label for="userName">Full Name</label>
                <input type="name" class="form-control" id="name" aria-describedby="nameHelp" placeholder="Enter your full name" required />
                <small id="nameHelp" class="form-text text-muted">Please enter your full name as it appears on official
                    documents. This helps us verify your identity and keep your account secure.</small>
            </div>
        </div>
        <div class="col">
            <div class="form-group">
                <label for="gender">Gender</label>
                <select class="form-control" id="gender" aria-describedby="genderHelp" required>
                    <option value="Male">Male</option>
                    <option value="Female" selected>Female</option>
                    <option value="Other">Other</option>
                </select>
                <small id="genderHelp" class="form-text text-muted">Select the gender you identify with. This information helps us personalize your experience and maintain accurate records.</small>
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col">
            <div class="form-group">
                <label for="contact">Contact Number (WhatsApp Preferred)</label>
                <input type="tel" class="form-control" id="contact" maxlength="10" aria-describedby="contactHelp" placeholder="Enter your contact number" required />
                <small id="contactHelp" class="form-text text-muted">Enter a valid 10-digit mobile number. Preferably one linked to WhatsApp for faster communication and updates.</small>
            </div>
        </div>
        <div class="col">
            <div class="form-group">
                <label for="email">Email Address</label>
                <input type="email" class="form-control" id="email" aria-describedby="emailHelp" placeholder="Enter your email id" required />
                <small id="emailHelp" class="form-text text-muted">Provide an active email address you check regularly. We'll use it to send important updates and account-related information.</small>
            </div>
        </div>
    </div>
